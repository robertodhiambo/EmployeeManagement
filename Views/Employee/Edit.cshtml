@model EmployeeManagement.Models.Employee

@{
    ViewData["Title"] = "Edit Employee";
}

<form asp-controller="employee" asp-action="edit" method="post" class="mt-3">
    <input hidden asp-for="Id" />
    <div class="form-group row">
        <label asp-for="Name" class="col-sm-2 col-form-label"></label>
        <div class="col-sm-10">
            <input asp-for="Name" class="form-control" placeholder="Name" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
    </div>

    <div class="form-group row">
        <label asp-for="Email" class="col-sm-2 col-form-label"></label>
        <div class="col-sm-10">
            <input asp-for="Email" class="form-control" placeholder="Email" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>
    </div>

    <div class="form-group row">
        <label asp-for="Department" class="col-sm-2 col-form-label"></label>
        <div class="col-sm-10">
            <select class="form-control selectpicker" asp-for="Department" asp-items="@Html.GetEnumSelectList(typeof(Dept))">
                <option selected="selected" value="">Please select</option>
            </select>
            <span asp-validation-for="Department" class="text-danger"></span>
        </div>
    </div>

    <div class="form-group">
        <div class="col-sm-10">
            <button type="submit" class="btn btn-primary m-1">Update</button>
            <a asp-controller="employee" asp-action="index" class="btn btn-primary">Cancel</a>
        </div>
    </div>
</form>